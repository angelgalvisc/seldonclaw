# SeldonClaw — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Anthropic API key (required for ontology, profiles, report)
ANTHROPIC_API_KEY=sk-ant-api03-...

# NullClaw gateway URL (default: http://localhost:3000)
# NULLCLAW_GATEWAY_URL=http://localhost:3000
